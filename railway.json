{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["jdk17", "maven"]
        },
        "install": {
          "cmd": "cd server-java && mvn clean package -DskipTests"
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd server-java && java -jar target/agri-trading-1.0.0.jar -Dserver.port=$PORT",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 600,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
