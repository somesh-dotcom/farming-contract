DATABASE_URL="postgresql://somesh@localhost:5432/contract_farming?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"
PORT=5004
NODE_ENV=development

# ============================================
# CONFIGURATION OPTIONS
# ============================================

# Application Settings
APP_NAME="Agricultural Commodity Trading Platform"
DEFAULT_CURRENCY=INR
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,kn

# CORS Settings
CORS_ORIGIN=*

# Database Settings
DB_SCHEMA=public

# Bangalore Location Settings
BANGALORE_LOCATIONS_ENABLED=true
DEFAULT_CITY=Bangalore
DEFAULT_STATE=Karnataka

# Contract Settings
CONTRACT_AUTO_COMPLETE=true
ADMIN_ONLY_STATUS_CHANGE=true
CONTRACT_STATUSES=DRAFT,PENDING,ACTIVE,COMPLETED,CANCELLED

# Transaction Settings
BUYER_TRANSACTION_VISIBILITY=true
ADMIN_DELETE_TRANSACTIONS=true
PAYMENT_TYPES=ADVANCE,PARTIAL,FINAL,REFUND,OTHER

# Market Price Settings
PRICE_UPDATE_INTERVAL=3600000
PRICE_HISTORY_DAYS=180
ANALYZE_PRICE_TRENDS=true

# Data File Settings (set to 'true' to load data from config/*.json files)
LOAD_PRODUCTS_FROM_FILE=false
LOAD_PRICES_FROM_FILE=false
LOAD_LOCATIONS_FROM_FILE=false
LOAD_USERS_FROM_FILE=false
LOAD_CONTRACTS_FROM_FILE=false

# ============================================
# FILE-BASED DATABASE OPTION
# ============================================

# Set to 'true' to use JSON files instead of PostgreSQL database
USE_FILE_DATABASE=true

# When using file database, set this to auto-save changes
FILE_DATABASE_AUTO_SAVE=true

# Main database file path (all data in one file)
FILE_DATABASE_PATH=./config/database.json

# Backup file path for exporting all data
FILE_DATABASE_BACKUP_PATH=./config/backup_all_data.json
